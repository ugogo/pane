<winuiex:WindowEx
    x:Class="CleanShotW.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CleanShotW.Controls"
    xmlns:winuiex="using:WinUIEx">

    <Grid Background="{StaticResource SurfaceBaseBrush}">
        <Ellipse
            Width="320"
            Height="320"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,-120,-80,0"
            Fill="{StaticResource AccentSoftBrush}"
            IsHitTestVisible="False" />
        <Ellipse
            Width="220"
            Height="220"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="-60,0,0,-40"
            Fill="#18000000"
            IsHitTestVisible="False" />

        <Border
            Margin="20"
            Padding="20"
            CornerRadius="{StaticResource RadiusLarge}"
            Background="{StaticResource GlassDeepBrush}"
            BorderBrush="{StaticResource GlassEdgeBrush}"
            BorderThickness="1">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock
                        Text="Settings"
                        FontFamily="{StaticResource DisplayFont}"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource InkPrimaryBrush}" />
                    <TextBlock
                        Text="Customize shortcuts and where screenshots are saved."
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="12"
                        Foreground="{StaticResource InkMutedBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="10">
                    <TextBlock
                        Text="SAVE FOLDER"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="10"
                        FontWeight="Bold"
                        Foreground="{StaticResource InkMutedBrush}"
                        CharacterSpacing="100" />

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="SaveFolderBox"
                            Grid.Column="0"
                            FontFamily="{StaticResource BodyFont}"
                            FontSize="12"
                            PlaceholderText="Choose a folder…"
                            TextWrapping="Wrap" />

                        <Button
                            Grid.Column="1"
                            Style="{StaticResource DebugTileButtonStyle}"
                            Click="OnBrowseFolderClicked">
                            <TextBlock Text="Browse" FontWeight="SemiBold" />
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="10">
                    <TextBlock
                        Text="SHORTCUTS"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="10"
                        FontWeight="Bold"
                        Foreground="{StaticResource InkMutedBrush}"
                        CharacterSpacing="100" />

                    <TextBlock
                        Text="Focus a field and press your shortcut."
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="10"
                        Foreground="{StaticResource InkMutedBrush}" />

                    <Grid ColumnSpacing="10" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="Full screen"
                            FontFamily="{StaticResource BodyFont}"
                            FontSize="11"
                            Foreground="{StaticResource InkMutedBrush}"
                            VerticalAlignment="Center" />
                        <controls:HotkeyCaptureBox
                            x:Name="FullScreenShortcutBox"
                            Grid.Row="0"
                            Grid.Column="1"
                            EnterPressed="OnShortcutEnterPressed" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Text="Region"
                            FontFamily="{StaticResource BodyFont}"
                            FontSize="11"
                            Foreground="{StaticResource InkMutedBrush}"
                            VerticalAlignment="Center" />
                        <controls:HotkeyCaptureBox
                            x:Name="RegionShortcutBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            EnterPressed="OnShortcutEnterPressed" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="10">
                    <TextBlock
                        Text="STARTUP"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="10"
                        FontWeight="Bold"
                        Foreground="{StaticResource InkMutedBrush}"
                        CharacterSpacing="100" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock
                                Text="Launch automatically"
                                FontFamily="{StaticResource BodyFont}"
                                FontSize="11"
                                Foreground="{StaticResource InkPrimaryBrush}" />
                            <TextBlock
                                Text="Start when you sign in, boot, or wake from sleep."
                                FontFamily="{StaticResource BodyFont}"
                                FontSize="10"
                                Foreground="{StaticResource InkMutedBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="LaunchAtStartupToggle"
                            Grid.Column="1"
                            VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="4" Spacing="10">
                    <Button
                        Style="{StaticResource DebugTilePrimaryStyle}"
                        HorizontalAlignment="Stretch"
                        Click="OnSaveClicked">
                        <TextBlock Text="Save settings" FontWeight="SemiBold" />
                    </Button>

                    <TextBlock
                        x:Name="StatusText"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="11"
                        Foreground="{StaticResource InkMutedBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</winuiex:WindowEx>
