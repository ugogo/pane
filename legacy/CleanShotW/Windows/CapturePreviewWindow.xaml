<winuiex:WindowEx
    x:Class="CleanShotW.Views.CapturePreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winuiex="using:WinUIEx">

    <Grid
        x:Name="RootHost"
        Background="Transparent"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

        <Grid
            x:Name="CardHost"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

            <Ellipse
                Width="140"
                Height="140"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-30,-30,0"
                Fill="{StaticResource AccentSoftBrush}"
                IsHitTestVisible="False" />

            <Border
                x:Name="CardShadow"
                Margin="0,0,8,8"
                CornerRadius="{StaticResource RadiusLarge}"
                Background="#55000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False" />

            <Border
                x:Name="CardBorder"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                CornerRadius="{StaticResource RadiusLarge}"
                BorderBrush="{StaticResource GlassEdgeBrush}"
                BorderThickness="1"
                Background="{StaticResource GlassDeepBrush}"
                Padding="8">

                <Grid x:Name="PreviewContent">
                    <Border
                        x:Name="ImageClipHost"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Background="#FF090910"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Image
                            x:Name="PreviewImage"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <Border
                        x:Name="HoverDimmer"
                        Opacity="0"
                        IsHitTestVisible="False"
                        Background="#AA0A0A12" />

                    <Border
                        x:Name="ActionButtonsHost"
                        Opacity="0"
                        IsHitTestVisible="False"
                        VerticalAlignment="Bottom"
                        Margin="8"
                        Padding="6"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Background="#CC14141C"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1">
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button
                                x:Name="CopyButton"
                                Grid.Column="0"
                                Style="{StaticResource OverlayTilePrimaryStyle}"
                                Content="Copy"
                                Click="OnCopyClicked" />

                            <Button
                                x:Name="SaveButton"
                                Grid.Column="1"
                                Style="{StaticResource OverlayTileButtonStyle}"
                                Content="Save"
                                Click="OnSaveClicked" />
                        </Grid>
                    </Border>

                    <Button
                        x:Name="DismissButton"
                        Style="{StaticResource OverlayDismissButtonStyle}"
                        Content="✕"
                        Opacity="0"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="8"
                        Click="OnDismissClicked" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</winuiex:WindowEx>
