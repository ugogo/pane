#!/bin/sh
# Enforce Conventional Commits on the subject line (see AGENTS.md > Git).
# Bypass with `git commit --no-verify` when genuinely needed.

msg_file="$1"
subject=$(head -n1 "$msg_file")

# Allow merge / revert / fixup / squash commits to pass untouched.
case "$subject" in
	"Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

# type(optional scope)(optional !): description
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?!?: .+'

if printf '%s' "$subject" | grep -Eq "$pattern"; then
	exit 0
fi

echo "✗ Commit message does not follow Conventional Commits." >&2
echo "  Subject: $subject" >&2
echo "" >&2
echo "  Expected: <type>(<optional scope>): <description>" >&2
echo "  Types:    feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert" >&2
echo "  Example:  feat(audio): add favorite-device toggle" >&2
exit 1
