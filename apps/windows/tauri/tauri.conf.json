{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pane",
  "version": "1.4.3",
  "identifier": "pane.prod",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "node ../../scripts/run-expo-cli.mjs start --web",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pane",
        "width": 900,
        "height": 600,
        "resizable": true,
        "center": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "color": "#21181ce8"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; font-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ugogo/pane/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5NTg5M0M2MkZBMEM2MTQKUldRVXhxQXZ4cE5ZYWFSYlJhWGxZOExFeUFSTXNRQU15a2FMVmdNODJ1WEpJUVBJaGxEcnBuZ0QK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/capture-shutter.wav": "capture-shutter.wav",
      "resources/identity/Pane-identity.msix": "identity/Pane-identity.msix",
      "resources/identity/pane-codesign.cer": "identity/pane-codesign.cer",
      "resources/identity/register-identity.ps1": "identity/register-identity.ps1",
      "resources/identity/unregister-identity.ps1": "identity/unregister-identity.ps1"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "installer-hooks.nsh"
      }
    }
  }
}
