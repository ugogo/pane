{
  "name": "@pane/companion",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "cross-env APP_VARIANT=dev expo start",
    "start:prod": "cross-env APP_VARIANT=prod expo start --no-dev --minify",
    "clear": "cross-env APP_VARIANT=dev expo start --clear",
    "clear:prod": "cross-env APP_VARIANT=prod expo start --no-dev --minify --clear",
    "ios": "expo run:ios --device",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@pane/protocol": "*",
    "@pane/query": "^0.0.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@tanstack/react-query": "^5.101.0",
    "expo": "^54.0.0",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  }
}
