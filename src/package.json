  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "lucide-react": "^1.16.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vite": "^5",
    "@choochmeque/tauri-windows-bundle": "^0.1.20"
  }
}
