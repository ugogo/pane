{
  "name": "home-tauri",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"npx tsc; npx vite build\"",
    "preview": "vite preview",
    "tauri": "tauri",
    "stop": "powershell -ExecutionPolicy Bypass -File ../scripts/stop.ps1",
