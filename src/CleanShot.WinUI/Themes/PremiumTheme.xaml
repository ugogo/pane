<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Refined dark glass palette inspired by CleanShot X -->
    <Color x:Key="GlassDeep">#E6181820</Color>
    <Color x:Key="GlassMid">#CC222230</Color>
    <Color x:Key="GlassEdge">#55FFFFFF</Color>
    <Color x:Key="AccentGlow">#FF6E8EFF</Color>
    <Color x:Key="AccentSoft">#336E8EFF</Color>
    <Color x:Key="InkPrimary">#FFF5F6FA</Color>
    <Color x:Key="InkMuted">#B3C4C8D4</Color>
    <Color x:Key="PillSurface">#F2FFFFFF</Color>
    <Color x:Key="PillHover">#FFFFFFFF</Color>
    <Color x:Key="DangerSoft">#33FF5A5A</Color>
    <Color x:Key="DangerInk">#FFFF8A8A</Color>
    <Color x:Key="SelectionStroke">#FF7B93FF</Color>
    <Color x:Key="SelectionFill">#337B93FF</Color>
    <Color x:Key="ShadeOverlay">#66080810</Color>

    <SolidColorBrush x:Key="GlassDeepBrush" Color="{StaticResource GlassDeep}" />
    <SolidColorBrush x:Key="GlassMidBrush" Color="{StaticResource GlassMid}" />
    <SolidColorBrush x:Key="GlassEdgeBrush" Color="{StaticResource GlassEdge}" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlow}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}" />
    <SolidColorBrush x:Key="InkPrimaryBrush" Color="{StaticResource InkPrimary}" />
    <SolidColorBrush x:Key="InkMutedBrush" Color="{StaticResource InkMuted}" />
    <SolidColorBrush x:Key="PillSurfaceBrush" Color="{StaticResource PillSurface}" />
    <SolidColorBrush x:Key="PillHoverBrush" Color="{StaticResource PillHover}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoft}" />
    <SolidColorBrush x:Key="DangerInkBrush" Color="{StaticResource DangerInk}" />
    <SolidColorBrush x:Key="SelectionStrokeBrush" Color="{StaticResource SelectionStroke}" />
    <SolidColorBrush x:Key="SelectionFillBrush" Color="{StaticResource SelectionFill}" />
    <SolidColorBrush x:Key="ShadeOverlayBrush" Color="{StaticResource ShadeOverlay}" />
    <Color x:Key="SurfaceBase">#FF0C0C12</Color>
    <Color x:Key="SurfaceRaised">#FF14141C</Color>
    <Color x:Key="AccentPrimary">#FF6E8EFF</Color>
    <Color x:Key="AccentSecondary">#FF8B7CFF</Color>

    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBase}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaised}" />
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}" />

    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI Variable Text</FontFamily>
    <CornerRadius x:Key="RadiusLarge">18</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">12</CornerRadius>

    <Style x:Key="PremiumPillButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PillSurfaceBrush}" />
        <Setter Property="Foreground" Value="#FF1A1A24" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="MaxWidth" Value="120" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border
                            x:Name="Shadow"
                            Background="#22000000"
                            CornerRadius="{StaticResource RadiusPill}"
                            Margin="0,3,0,0"
                            Opacity="0.45" />
                        <Border
                            x:Name="Surface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusPill}"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}" />
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Surface"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Surface"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.88"
                                            Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IconCircleButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="#CCFFFFFF" />
        <Setter Property="Foreground" Value="#FF1A1A24" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="17" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="Surface"
                        Background="{TemplateBinding Background}"
                        CornerRadius="17"
                        BorderBrush="#44FFFFFF"
                        BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DismissIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconCircleButtonStyle}">
        <Setter Property="Background" Value="#D9FFFFFF" />
        <Setter Property="Foreground" Value="#FF2A2A34" />
    </Style>

    <Style x:Key="DebugTileButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#1AFFFFFF" />
        <Setter Property="Foreground" Value="{StaticResource InkPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#22FFFFFF" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border
                            x:Name="Glow"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Background="{StaticResource AccentSoftBrush}"
                            Opacity="0" />
                        <Border
                            x:Name="Surface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusMedium}">
                            <ContentPresenter
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="Center"
                                Content="{TemplateBinding Content}" />
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.15" />
                                        <ColorAnimation
                                            Storyboard.TargetName="Surface"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#28FFFFFF"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Surface"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.82"
                                            Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DebugTilePrimaryStyle" TargetType="Button" BasedOn="{StaticResource DebugTileButtonStyle}">
        <Setter Property="BorderBrush" Value="#556E8EFF" />
        <Setter Property="Background" Value="#1F6E8EFF" />
    </Style>

    <Style x:Key="DebugTileMutedStyle" TargetType="Button" BasedOn="{StaticResource DebugTileButtonStyle}">
        <Setter Property="BorderBrush" Value="#18FFFFFF" />
        <Setter Property="Background" Value="#0FFFFFFF" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
    </Style>

    <Style x:Key="OverlayTileButtonStyle" TargetType="Button" BasedOn="{StaticResource DebugTileButtonStyle}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="OverlayTilePrimaryStyle" TargetType="Button" BasedOn="{StaticResource OverlayTileButtonStyle}">
        <Setter Property="BorderBrush" Value="#556E8EFF" />
        <Setter Property="Background" Value="#1F6E8EFF" />
    </Style>

    <Style x:Key="OverlayDismissButtonStyle" TargetType="Button" BasedOn="{StaticResource DismissIconButtonStyle}">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="FontSize" Value="10" />
    </Style>

</ResourceDictionary>
