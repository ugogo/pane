<winuiex:WindowEx
    x:Class="CleanShot.WinUI.Views.CaptureFullSizePreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winuiex="using:WinUIEx">

    <Grid
        x:Name="RootHost"
        Background="Transparent"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

        <Border
            x:Name="CardShadow"
            Margin="0,0,10,10"
            CornerRadius="{StaticResource RadiusLarge}"
            Background="#66000000"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            IsHitTestVisible="False" />

        <Border
            x:Name="CardBorder"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="{StaticResource RadiusLarge}"
            BorderBrush="{StaticResource GlassEdgeBrush}"
            BorderThickness="1"
            Background="{StaticResource GlassDeepBrush}"
            Padding="10">

            <Grid x:Name="PreviewContent">
                <Image
                    x:Name="FullSizeImage"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />

                <Button
                    x:Name="DismissButton"
                    Style="{StaticResource OverlayDismissButtonStyle}"
                    Content="✕"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="4"
                    Click="OnDismissClicked" />
            </Grid>
        </Border>
    </Grid>
</winuiex:WindowEx>
