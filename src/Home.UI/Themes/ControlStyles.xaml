        <Setter Property="Padding" Value="10,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="DeviceChipStyle" TargetType="Border" BasedOn="{StaticResource GlassCardCompactStyle}">
