<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI Variable Text</FontFamily>

    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeBodySmall">13</x:Double>
    <x:Double x:Key="FontSizeSubtitle">16</x:Double>
    <x:Double x:Key="FontSizePageTitle">28</x:Double>
    <x:Double x:Key="FontSizeHeroTitle">36</x:Double>

    <Thickness x:Key="PagePadding">48,40,48,40</Thickness>
    <x:Double x:Key="PageContentMaxWidth">1260</x:Double>
    <x:Double x:Key="PageWideContentMaxWidth">1420</x:Double>
    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">12</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">18</CornerRadius>
</ResourceDictionary>
