    <!-- Static fallbacks keep overlay windows and code-behind lookups resolving outside theme-aware bindings. -->
    <SolidColorBrush x:Key="HubBackdropBrush" Color="#FF202020" />
    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="#FF202020" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#FF2B2B2B" />
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="#FF2B2B2B" />
    <SolidColorBrush x:Key="SurfaceCardHoverBrush" Color="#FF303030" />
    <SolidColorBrush x:Key="ControlFillBrush" Color="#FF323232" />
    <SolidColorBrush x:Key="ControlFillHoverBrush" Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="ControlFillPressedBrush" Color="#FF242424" />
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="#2EFFFFFF" />
    <SolidColorBrush x:Key="ControlStrokeStrongBrush" Color="#40FFFFFF" />
    <SolidColorBrush x:Key="FocusStrokeBrush" Color="#FF60CDFF" />
