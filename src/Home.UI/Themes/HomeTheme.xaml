            <SolidColorBrush x:Key="PillHoverBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="ShadeOverlayBrush" Color="#66000000" />
            <SolidColorBrush x:Key="SelectionStrokeBrush" Color="#FF60CDFF" />
            <SolidColorBrush x:Key="SelectionFillBrush" Color="#3360CDFF" />
            <SolidColorBrush x:Key="GlassDeepBrush" Color="#FF202020" />
            <SolidColorBrush x:Key="GlassMidBrush" Color="#FF2B2B2B" />
            <SolidColorBrush x:Key="GlassEdgeBrush" Color="#2EFFFFFF" />
