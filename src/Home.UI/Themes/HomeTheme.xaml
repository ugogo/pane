    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#8CFFFFFF" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#FF60CDFF" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#FF8AD8FF" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#3360CDFF" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#3360CDFF" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#33FF99A4" />
    <SolidColorBrush x:Key="DangerInkBrush" Color="#FFFFB3BB" />
    <SolidColorBrush x:Key="PillSurfaceBrush" Color="#F2FFFFFF" />
    <SolidColorBrush x:Key="PillHoverBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ShadeOverlayBrush" Color="#66000000" />
    <SolidColorBrush x:Key="SelectionStrokeBrush" Color="#FF60CDFF" />
    <SolidColorBrush x:Key="SelectionFillBrush" Color="#3360CDFF" />
    <SolidColorBrush x:Key="GlassDeepBrush" Color="#FF202020" />
    <SolidColorBrush x:Key="GlassMidBrush" Color="#FF2B2B2B" />
    <SolidColorBrush x:Key="GlassEdgeBrush" Color="#40FFFFFF" />
    <SolidColorBrush x:Key="InkPrimaryBrush" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="InkMutedBrush" Color="#A6FFFFFF" />

    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI Variable Text</FontFamily>

    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeBodySmall">13</x:Double>
    <x:Double x:Key="FontSizeSubtitle">16</x:Double>
    <x:Double x:Key="FontSizePageTitle">28</x:Double>

    <Thickness x:Key="PagePadding">32,28,32,32</Thickness>
    <x:Double x:Key="PageContentMaxWidth">760</x:Double>
    <x:Double x:Key="PageWideContentMaxWidth">920</x:Double>
    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">12</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

    <Style x:Key="HubSearchBoxStyle" TargetType="AutoSuggestBox">
        <Setter Property="MinWidth" Value="260" />
        <Setter Property="MaxWidth" Value="420" />
        <Setter Property="Margin" Value="12,6,16,6" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="PlaceholderText" Value="Search settings" />
    </Style>

    <Style x:Key="PageScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="PageContentStackStyle" TargetType="StackPanel">
        <Setter Property="Padding" Value="{StaticResource PagePadding}" />
        <Setter Property="Spacing" Value="20" />
        <Setter Property="MaxWidth" Value="{StaticResource PageContentMaxWidth}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PageWideContentStackStyle" TargetType="StackPanel" BasedOn="{StaticResource PageContentStackStyle}">
        <Setter Property="MaxWidth" Value="{StaticResource PageWideContentMaxWidth}" />
    </Style>

    <Style x:Key="PageHeadingBlockStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="6" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="PageMainHeadingStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizePageTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="SettingsCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceCardBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="SettingsListCardStyle" TargetType="Border" BasedOn="{StaticResource SettingsCardStyle}">
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="SettingsFormRowStyle" TargetType="Grid">
        <Setter Property="MinHeight" Value="52" />
        <Setter Property="ColumnSpacing" Value="16" />
        <Setter Property="RowSpacing" Value="6" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="SettingsListRowStyle" TargetType="Grid" BasedOn="{StaticResource SettingsFormRowStyle}">
        <Setter Property="Padding" Value="18,14" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodySmall}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style x:Key="SettingsSectionDescriptionStyle" TargetType="TextBlock" BasedOn="{StaticResource PageSubtitleStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="SettingsRowDividerStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{ThemeResource ControlStrokeBrush}" />
        <Setter Property="Margin" Value="0,4,0,4" />
    </Style>

    <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="SettingsDescriptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingsDescriptionStyle}">
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="HubInputTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodySmall}" />
        <Setter Property="Background" Value="{ThemeResource ControlFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeStrongBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
    </Style>

    <Style x:Key="HubToggleSwitchStyle" TargetType="ToggleSwitch">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodySmall}" />
        <Setter Property="OnContent" Value="On" />
        <Setter Property="OffContent" Value="Off" />
    </Style>

    <Style x:Key="HubListViewStyle" TargetType="ListView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="SelectionMode" Value="Single" />
    </Style>

    <Style x:Key="HubListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="CommandRowStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="8" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="DebugTileButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource ControlFillBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodySmall}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="DebugTilePrimaryStyle" TargetType="Button" BasedOn="{StaticResource DebugTileButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource AccentPrimaryBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextOnAccentBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AccentPrimaryBrush}" />
    </Style>

    <Style x:Key="DebugTileMutedStyle" TargetType="Button" BasedOn="{StaticResource DebugTileButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeBrush}" />
    </Style>

    <Style x:Key="HubPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DebugTilePrimaryStyle}" />
    <Style x:Key="HubSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DebugTileButtonStyle}" />
    <Style x:Key="HubGhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DebugTileMutedStyle}" />

    <Style x:Key="IconCircleButtonStyle" TargetType="Button" BasedOn="{StaticResource DebugTileButtonStyle}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="DismissIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconCircleButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource PillSurfaceBrush}" />
        <Setter Property="Foreground" Value="#FF1A1A1A" />
        <Setter Property="BorderBrush" Value="#33000000" />
    </Style>

    <Style x:Key="PremiumPillButtonStyle" TargetType="Button" BasedOn="{StaticResource DebugTilePrimaryStyle}">
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="MaxWidth" Value="140" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="OverlayTileButtonStyle" TargetType="Button" BasedOn="{StaticResource DebugTileButtonStyle}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="OverlayTilePrimaryStyle" TargetType="Button" BasedOn="{StaticResource OverlayTileButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource AccentPrimaryBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextOnAccentBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AccentPrimaryBrush}" />
    </Style>

    <Style x:Key="OverlayDismissButtonStyle" TargetType="Button" BasedOn="{StaticResource DismissIconButtonStyle}">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>
</ResourceDictionary>
