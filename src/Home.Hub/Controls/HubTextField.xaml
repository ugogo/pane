<UserControl
    x:Class="Home.Hub.Controls.HubTextField"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch">

    <StackPanel Spacing="6">
        <TextBlock
            x:Name="LabelBlock"
            Style="{StaticResource SettingsLabelStyle}"
            Visibility="Collapsed" />
        <Border Style="{StaticResource HubFieldChromeStyle}">
            <TextBox
                x:Name="InputBox"
                Style="{StaticResource HubFieldTextStyle}"
                HorizontalAlignment="Stretch"
                TextWrapping="NoWrap" />
        </Border>
    </StackPanel>
</UserControl>
