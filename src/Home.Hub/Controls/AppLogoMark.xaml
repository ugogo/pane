<UserControl
    x:Class="Home.Hub.Controls.AppLogoMark"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="32"
    d:DesignHeight="32">

    <Border
        x:Name="Tile"
        Background="#FF121218"
        CornerRadius="8"
        Padding="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,2,2"
                Background="{ThemeResource LogoTileInactiveBrush}"
                CornerRadius="5,5,5,0" />
            <Border
                Grid.Row="0"
                Grid.Column="1"
                Margin="2,0,0,2"
                Background="{ThemeResource LogoTileInactiveBrush}"
                CornerRadius="5,5,0,5" />
            <Border
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,2,2,0"
                Background="{ThemeResource LogoTileAccentBrush}"
                CornerRadius="5,0,5,5" />
            <Border
                Grid.Row="1"
                Grid.Column="1"
                Margin="2,2,0,0"
                Background="{ThemeResource LogoTileInactiveBrush}"
                CornerRadius="0,5,5,5" />
        </Grid>
    </Border>
</UserControl>
