<UserControl
    x:Class="Home.Hub.Controls.AmbientGlowLayer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    IsHitTestVisible="False">

    <Grid>
        <Rectangle Fill="{ThemeResource HubBackdropBrush}" />

        <Rectangle Opacity="0.95">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF0C0C12" Offset="0" />
                    <GradientStop Color="#FF12121A" Offset="0.5" />
                    <GradientStop Color="#FF0C0C12" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Opacity="0.45">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#22B8F53A" Offset="0" />
                    <GradientStop Color="#000C0C12" Offset="0.45" />
                    <GradientStop Color="#188B7CFF" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</UserControl>
