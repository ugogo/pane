<windowex:WindowEx
    x:Class="Home.Hub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:windowex="using:WinUIEx"
    xmlns:notify="using:H.NotifyIcon"
    xmlns:controls="using:Home.Hub.Controls">

    <Grid Loaded="OnRootLoaded" Background="{ThemeResource HubBackdropBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Height="32" Background="Transparent" />

        <Grid Grid.Row="1">
            <controls:AmbientGlowLayer HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:HubSidebar
                    x:Name="Sidebar"
                    Grid.Column="0"
                    Width="220"
                    NavigationRequested="OnSidebarNavigationRequested" />

                <Frame
                    x:Name="ContentFrame"
                    Grid.Column="1"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch" />
            </Grid>
        </Grid>

        <notify:TaskbarIcon
            x:Name="TrayIcon"
            ToolTipText="Home"
            MenuActivation="RightClick"
            DoubleTapped="OnOpenHomeRequested" />
    </Grid>
</windowex:WindowEx>
