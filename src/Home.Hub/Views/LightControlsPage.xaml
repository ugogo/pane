<Page
    x:Class="Home.Hub.Views.LightControlsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:modules="using:Home.Core.Modules">

    <ScrollViewer>
        <StackPanel Padding="28" Spacing="20" MaxWidth="920">
            <StackPanel Spacing="6">
                <TextBlock
                    Text="Light Controls"
                    FontFamily="{StaticResource DisplayFont}"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource InkPrimaryBrush}" />
                <TextBlock
                    x:Name="StatusText"
                    Foreground="{StaticResource InkMutedBrush}"
                    FontFamily="{StaticResource BodyFont}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Pivot x:Name="MainPivot">
                <PivotItem Header="Devices">
                    <StackPanel Spacing="16" Padding="0,12,0,0">
                        <StackPanel x:Name="SetupPanel" Spacing="12">
                            <TextBlock
                                x:Name="SetupText"
                                Foreground="{StaticResource InkMutedBrush}"
                                FontFamily="{StaticResource BodyFont}"
                                TextWrapping="WrapWholeWords" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    x:Name="SetupButton"
                                    Style="{StaticResource DebugTilePrimaryStyle}"
                                    Click="OnSetupClicked">
                                    <TextBlock Text="Download and set up" FontWeight="SemiBold" />
                                </Button>
                                <Button
                                    Style="{StaticResource DebugTileButtonStyle}"
                                    Click="OnRetryClicked">
                                    <TextBlock Text="Retry" FontWeight="SemiBold" />
                                </Button>
                                <Button
                                    Style="{StaticResource DebugTileMutedStyle}"
                                    Click="OnOpenReleasesClicked">
                                    <TextBlock Text="Open releases" FontWeight="SemiBold" />
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="MainPanel" Spacing="16" Visibility="Collapsed">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="SelectedDeviceText"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource InkPrimaryBrush}" />
                                <Button
                                    Grid.Column="1"
                                    Style="{StaticResource DebugTileButtonStyle}"
                                    Click="OnRefreshClicked">
                                    <TextBlock Text="Refresh" FontWeight="SemiBold" />
                                </Button>
                                <Button
                                    Grid.Column="2"
                                    Style="{StaticResource DebugTilePrimaryStyle}"
                                    Click="OnApplyAllClicked">
                                    <TextBlock Text="Apply again" FontWeight="SemiBold" />
                                </Button>
                            </Grid>

                            <ListView
                                x:Name="DevicesList"
                                SelectionChanged="OnDeviceSelectionChanged"
                                IsItemClickEnabled="True">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="modules:LightControlsDevice">
                                        <StackPanel Spacing="4" Padding="4">
                                            <TextBlock
                                                Text="{x:Bind Name}"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource InkPrimaryBrush}" />
                                            <TextBlock
                                                Text="{x:Bind Details}"
                                                Foreground="{StaticResource InkMutedBrush}"
                                                FontSize="12"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock
                                x:Name="DevicesEmptyText"
                                Text="No compatible devices were reported."
                                Foreground="{StaticResource InkMutedBrush}"
                                Visibility="Collapsed" />

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Color"
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="11"
                                    Foreground="{StaticResource InkMutedBrush}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        x:Name="ColorPreview"
                                        Width="44"
                                        Height="44"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource GlassEdgeBrush}"
                                        BorderThickness="1" />
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock
                                            x:Name="ColorText"
                                            FontFamily="{StaticResource BodyFont}"
                                            Foreground="{StaticResource InkPrimaryBrush}" />
                                        <Button
                                            x:Name="ColorPickerButton"
                                            Style="{StaticResource DebugTileButtonStyle}"
                                            Click="OnChooseColorClicked">
                                            <TextBlock Text="Choose color" FontWeight="SemiBold" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Brightness"
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="11"
                                    Foreground="{StaticResource InkMutedBrush}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider
                                        x:Name="BrightnessSlider"
                                        Grid.Column="0"
                                        Minimum="1"
                                        Maximum="100"
                                        ValueChanged="OnBrightnessChanged" />
                                    <TextBlock
                                        x:Name="BrightnessText"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource InkPrimaryBrush}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Built-in swatches"
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="11"
                                    Foreground="{StaticResource InkMutedBrush}" />
                                <StackPanel x:Name="BuiltInSwatchesPanel" Orientation="Horizontal" Spacing="8" />
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Recent custom colors"
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="11"
                                    Foreground="{StaticResource InkMutedBrush}" />
                                <TextBlock
                                    x:Name="RecentEmptyText"
                                    Text="Pick a custom color to save it here."
                                    Foreground="{StaticResource InkMutedBrush}"
                                    FontSize="11"
                                    Visibility="Collapsed" />
                                <StackPanel x:Name="RecentSwatchesPanel" Orientation="Horizontal" Spacing="8" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </PivotItem>

                <PivotItem Header="Connection">
                    <Frame x:Name="ConnectionFrame" />
                </PivotItem>
            </Pivot>
        </StackPanel>
    </ScrollViewer>
</Page>
