<Page
    x:Class="Home.Hub.Views.LightControlsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
        <StackPanel Style="{StaticResource PageContentStackStyle}">
            <StackPanel Style="{StaticResource PageHeadingBlockStyle}">
                <TextBlock
                    Text="Light Controls"
                    Style="{StaticResource PageMainHeadingStyle}" />
                <TextBlock
                    Text="Control RGB devices connected through OpenRGB and direct backends."
                    Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="ConnectionStatusText"
                        VerticalAlignment="Center"
                        Style="{StaticResource StatusTextStyle}" />
                    <StackPanel Grid.Column="1" Style="{StaticResource CommandRowStyle}">
                        <ProgressRing
                            x:Name="ConnectionProgress"
                            Width="16"
                            Height="16"
                            IsActive="False"
                            Visibility="Collapsed" />
                        <Button
                            x:Name="ConnectButton"
                            Style="{StaticResource DebugTileButtonStyle}"
                            Click="OnConnectClicked">
                            <TextBlock x:Name="ConnectButtonText" Text="Connect" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                x:Name="SetupPanelHost"
                Style="{StaticResource SettingsCardStyle}">
                <StackPanel x:Name="SetupPanel" Spacing="12">
                    <TextBlock
                        Text="Setup required"
                        Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock
                        x:Name="SetupText"
                        Style="{StaticResource SettingsDescriptionStyle}" />
                    <StackPanel Style="{StaticResource CommandRowStyle}">
                        <Button
                            x:Name="SetupButton"
                            Style="{StaticResource DebugTilePrimaryStyle}"
                            Click="OnSetupClicked">
                            <TextBlock Text="Download and set up" FontWeight="SemiBold" />
                        </Button>
                        <Button
                            Style="{StaticResource DebugTileMutedStyle}"
                            Click="OnOpenReleasesClicked">
                            <TextBlock Text="Open releases" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel x:Name="MainPanel" Spacing="16" Visibility="Collapsed">
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="14">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="SelectedDeviceText"
                                VerticalAlignment="Center"
                                Style="{StaticResource SettingsLabelStyle}" />
                            <Button
                                Grid.Column="1"
                                Style="{StaticResource DebugTileButtonStyle}"
                                Click="OnRefreshClicked">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Refresh" />
                                    <TextBlock Text="Refresh" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button
                                Grid.Column="2"
                                Style="{StaticResource DebugTilePrimaryStyle}"
                                Click="OnApplyAllClicked">
                                <TextBlock Text="Apply again" FontWeight="SemiBold" />
                            </Button>
                        </Grid>

                        <ListView
                            x:Name="DevicesList"
                            Style="{StaticResource HubListViewStyle}"
                            ItemContainerStyle="{StaticResource HubListViewItemStyle}"
                            SelectionChanged="OnDeviceSelectionChanged"
                            IsItemClickEnabled="True">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="4" Padding="4">
                                        <TextBlock
                                            Text="{Binding Name}"
                                            Style="{StaticResource SettingsLabelStyle}" />
                                        <TextBlock
                                            Text="{Binding Details}"
                                            Style="{StaticResource SettingsDescriptionStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock
                            x:Name="DevicesEmptyText"
                            Text="No compatible devices were reported."
                            Style="{StaticResource StatusTextStyle}"
                            Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="DeviceControlsPanel"
                    Style="{StaticResource SettingsCardStyle}"
                    Opacity="1">
                    <StackPanel Spacing="16">
                        <StackPanel x:Name="DeviceControlsContent" Spacing="16">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Color"
                                    Style="{StaticResource SectionHeaderStyle}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        x:Name="ColorPreview"
                                        Width="44"
                                        Height="44"
                                        CornerRadius="8"
                                        BorderBrush="{ThemeResource ControlStrokeStrongBrush}"
                                        BorderThickness="1" />
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock
                                            x:Name="ColorText"
                                            Style="{StaticResource StatusTextStyle}" />
                                        <Button
                                            x:Name="ColorPickerButton"
                                            Style="{StaticResource DebugTileButtonStyle}"
                                            Click="OnChooseColorClicked">
                                            <TextBlock Text="Choose color" FontWeight="SemiBold" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Brightness"
                                    Style="{StaticResource SectionHeaderStyle}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider
                                        x:Name="BrightnessSlider"
                                        Grid.Column="0"
                                        Minimum="1"
                                        Maximum="100"
                                        ValueChanged="OnBrightnessChanged" />
                                    <TextBlock
                                        x:Name="BrightnessText"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextPrimaryBrush}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Swatches"
                                    Style="{StaticResource SectionHeaderStyle}" />
                                <StackPanel x:Name="BuiltInSwatchesPanel" Orientation="Horizontal" Spacing="8" />
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Recent"
                                    Style="{StaticResource SectionHeaderStyle}" />
                                <TextBlock
                                    x:Name="RecentEmptyText"
                                    Text="Pick a custom color to save it here."
                                    Style="{StaticResource StatusTextStyle}"
                                    Visibility="Collapsed" />
                                <StackPanel x:Name="RecentSwatchesPanel" Orientation="Horizontal" Spacing="8" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock
                        Text="Advanced connection settings"
                        Style="{StaticResource SectionHeaderStyle}" />

                    <TextBox
                        x:Name="HostBox"
                        Header="Host"
                        Style="{StaticResource HubInputTextBoxStyle}" />

                    <NumberBox
                        x:Name="PortBox"
                        Header="Port"
                        Minimum="1"
                        Maximum="65535"
                        SpinButtonPlacementMode="Inline" />

                    <TextBox
                        x:Name="OpenRgbPathBox"
                        Header="OpenRGB executable (optional)"
                        Style="{StaticResource HubInputTextBoxStyle}"
                        PlaceholderText="Auto-detect if empty" />

                    <ToggleSwitch
                        x:Name="LogitechToggle"
                        Header="Logitech direct control"
                        Style="{StaticResource HubToggleSwitchStyle}" />

                    <ToggleSwitch
                        x:Name="DxLightToggle"
                        Header="DX Light direct USB control"
                        Style="{StaticResource HubToggleSwitchStyle}" />

                    <Button
                        Style="{StaticResource DebugTilePrimaryStyle}"
                        HorizontalAlignment="Left"
                        MinWidth="180"
                        Click="OnSaveAdvancedSettingsClicked">
                        <TextBlock Text="Save and reconnect" FontWeight="SemiBold" />
                    </Button>

                    <TextBlock
                        x:Name="AdvancedSettingsStatusText"
                        Style="{StaticResource StatusTextStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
