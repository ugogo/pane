<Page
    x:Class="Home.Hub.Views.LightControlsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel
            Padding="28"
            Spacing="20"
            MaxWidth="{StaticResource PageContentMaxWidth}"
            HorizontalAlignment="Center">
            <StackPanel Spacing="6">
                <TextBlock
                    Text="Light Controls"
                    FontFamily="{StaticResource DisplayFont}"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource InkPrimaryBrush}" />
                <TextBlock
                    Text="Control RGB devices connected through OpenRGB and direct backends."
                    FontFamily="{StaticResource BodyFont}"
                    Foreground="{StaticResource InkMutedBrush}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border
                Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource GlassEdgeBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="ConnectionStatusText"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="13"
                        Foreground="{StaticResource InkMutedBrush}"
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <ProgressRing
                            x:Name="ConnectionProgress"
                            Width="16"
                            Height="16"
                            IsActive="False"
                            Visibility="Collapsed" />
                        <Button
                            x:Name="ConnectButton"
                            Style="{StaticResource DebugTileButtonStyle}"
                            Click="OnConnectClicked">
                            <TextBlock x:Name="ConnectButtonText" Text="Connect" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                x:Name="SetupPanelHost"
                Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource GlassEdgeBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
                <StackPanel x:Name="SetupPanel" Spacing="12">
                    <TextBlock
                        Text="Setup required"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource InkMutedBrush}" />
                    <TextBlock
                        x:Name="SetupText"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="12"
                        Foreground="{StaticResource InkMutedBrush}"
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="SetupButton"
                            Style="{StaticResource DebugTilePrimaryStyle}"
                            Click="OnSetupClicked">
                            <TextBlock Text="Download and set up" FontWeight="SemiBold" />
                        </Button>
                        <Button
                            Style="{StaticResource DebugTileMutedStyle}"
                            Click="OnOpenReleasesClicked">
                            <TextBlock Text="Open releases" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel x:Name="MainPanel" Spacing="16" Visibility="Collapsed">
                <Border
                    Background="{StaticResource SurfaceRaisedBrush}"
                    BorderBrush="{StaticResource GlassEdgeBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                    <StackPanel Spacing="14">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="SelectedDeviceText"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource BodyFont}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource InkPrimaryBrush}" />
                            <Button
                                Grid.Column="1"
                                Style="{StaticResource DebugTileButtonStyle}"
                                Click="OnRefreshClicked">
                                <TextBlock Text="Refresh" FontWeight="SemiBold" />
                            </Button>
                            <Button
                                Grid.Column="2"
                                Style="{StaticResource DebugTilePrimaryStyle}"
                                Click="OnApplyAllClicked">
                                <TextBlock Text="Apply again" FontWeight="SemiBold" />
                            </Button>
                        </Grid>

                        <ListView
                            x:Name="DevicesList"
                            SelectionChanged="OnDeviceSelectionChanged"
                            IsItemClickEnabled="True">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="4" Padding="4">
                                        <TextBlock
                                            Text="{Binding Name}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource InkPrimaryBrush}" />
                                        <TextBlock
                                            Text="{Binding Details}"
                                            Foreground="{StaticResource InkMutedBrush}"
                                            FontSize="12"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock
                            x:Name="DevicesEmptyText"
                            Text="No compatible devices were reported."
                            FontFamily="{StaticResource BodyFont}"
                            FontSize="12"
                            Foreground="{StaticResource InkMutedBrush}"
                            Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="DeviceControlsPanel"
                    Background="{StaticResource SurfaceRaisedBrush}"
                    BorderBrush="{StaticResource GlassEdgeBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16"
                    Opacity="1">
                    <StackPanel Spacing="16">
                        <StackPanel x:Name="DeviceControlsContent" Spacing="16">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Color"
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource InkMutedBrush}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        x:Name="ColorPreview"
                                        Width="44"
                                        Height="44"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource GlassEdgeBrush}"
                                        BorderThickness="1" />
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock
                                            x:Name="ColorText"
                                            FontFamily="{StaticResource BodyFont}"
                                            Foreground="{StaticResource InkPrimaryBrush}" />
                                        <Button
                                            x:Name="ColorPickerButton"
                                            Style="{StaticResource DebugTileButtonStyle}"
                                            Click="OnChooseColorClicked">
                                            <TextBlock Text="Choose color" FontWeight="SemiBold" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Brightness"
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource InkMutedBrush}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider
                                        x:Name="BrightnessSlider"
                                        Grid.Column="0"
                                        Minimum="1"
                                        Maximum="100"
                                        ValueChanged="OnBrightnessChanged" />
                                    <TextBlock
                                        x:Name="BrightnessText"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource InkPrimaryBrush}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Swatches"
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource InkMutedBrush}" />
                                <StackPanel x:Name="BuiltInSwatchesPanel" Orientation="Horizontal" Spacing="8" />
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="Recent"
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource InkMutedBrush}" />
                                <TextBlock
                                    x:Name="RecentEmptyText"
                                    Text="Pick a custom color to save it here."
                                    FontFamily="{StaticResource BodyFont}"
                                    FontSize="12"
                                    Foreground="{StaticResource InkMutedBrush}"
                                    Visibility="Collapsed" />
                                <StackPanel x:Name="RecentSwatchesPanel" Orientation="Horizontal" Spacing="8" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border
                Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource GlassEdgeBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
                <StackPanel Spacing="14">
                    <TextBlock
                        Text="Advanced connection settings"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource InkMutedBrush}" />

                    <TextBox
                        x:Name="HostBox"
                        Header="Host"
                        FontFamily="{StaticResource BodyFont}" />

                    <NumberBox
                        x:Name="PortBox"
                        Header="Port"
                        Minimum="1"
                        Maximum="65535"
                        SpinButtonPlacementMode="Inline" />

                    <TextBox
                        x:Name="OpenRgbPathBox"
                        Header="OpenRGB executable (optional)"
                        FontFamily="{StaticResource BodyFont}"
                        PlaceholderText="Auto-detect if empty" />

                    <ToggleSwitch
                        x:Name="LogitechToggle"
                        Header="Logitech direct control"
                        OnContent="On"
                        OffContent="Off" />

                    <ToggleSwitch
                        x:Name="DxLightToggle"
                        Header="DX Light direct USB control"
                        OnContent="On"
                        OffContent="Off" />

                    <Button
                        Style="{StaticResource DebugTilePrimaryStyle}"
                        HorizontalAlignment="Left"
                        MinWidth="180"
                        Click="OnSaveAdvancedSettingsClicked">
                        <TextBlock Text="Save and reconnect" FontWeight="SemiBold" />
                    </Button>

                    <TextBlock
                        x:Name="AdvancedSettingsStatusText"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="11"
                        Foreground="{StaticResource InkMutedBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
