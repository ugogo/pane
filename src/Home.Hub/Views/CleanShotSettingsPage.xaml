<Page
    x:Class="Home.Hub.Views.CleanShotSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Home.Hub.Controls"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <ScrollViewer Style="{StaticResource PageModuleScrollViewerStyle}">
        <StackPanel Style="{StaticResource PageModuleContentStackStyle}">
            <StackPanel Style="{StaticResource PageHeadingBlockStyle}">
                <TextBlock
                    Text="CleanShot"
                    Style="{StaticResource PageMainHeadingStyle}" />
                <TextBlock
                    Text="Customize shortcuts and where screenshots are saved."
                    Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel Style="{StaticResource SettingsSectionStyle}">
                        <TextBlock
                            Text="Save folder"
                            Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock
                            Text="Choose where new screenshots are written."
                            Style="{StaticResource SettingsSectionDescriptionStyle}" />

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                x:Name="SaveFolderBox"
                                Grid.Column="0"
                                Style="{StaticResource HubInputTextBoxStyle}"
                                PlaceholderText="Choose a folder…"
                                TextWrapping="Wrap" />

                            <Button
                                Grid.Column="1"
                                Style="{StaticResource DebugTileButtonStyle}"
                                Click="OnBrowseFolderClicked">
                                <TextBlock Text="Browse" FontWeight="SemiBold" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Border Style="{StaticResource SettingsRowDividerStyle}" />

                    <StackPanel Style="{StaticResource SettingsSectionStyle}">
                        <TextBlock
                            Text="Shortcuts"
                            Style="{StaticResource SectionHeaderStyle}" />

                        <TextBlock
                            Text="Focus a field and press your shortcut."
                            Style="{StaticResource SettingsSectionDescriptionStyle}" />

                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="Full screen"
                                Style="{StaticResource SettingsDescriptionStyle}"
                                VerticalAlignment="Center" />
                            <controls:HotkeyCaptureBox
                                x:Name="FullScreenShortcutBox"
                                Grid.Row="0"
                                Grid.Column="1"
                                AutomationProperties.Name="Full screen shortcut"
                                EnterPressed="OnShortcutEnterPressed" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="Region"
                                Style="{StaticResource SettingsDescriptionStyle}"
                                VerticalAlignment="Center" />
                            <controls:HotkeyCaptureBox
                                x:Name="RegionShortcutBox"
                                Grid.Row="1"
                                Grid.Column="1"
                                AutomationProperties.Name="Region shortcut"
                                EnterPressed="OnShortcutEnterPressed" />
                        </Grid>
                    </StackPanel>

                    <Button
                        Style="{StaticResource DebugTilePrimaryStyle}"
                        HorizontalAlignment="Stretch"
                        Click="OnSaveClicked">
                        <TextBlock Text="Save settings" FontWeight="SemiBold" />
                    </Button>

                    <TextBlock
                        x:Name="StatusText"
                        Style="{StaticResource StatusTextStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
