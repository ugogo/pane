<Page
    x:Class="Home.Hub.Views.CleanShotSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Home.Hub.Controls">

    <ScrollViewer>
        <StackPanel Padding="28" Spacing="20" MaxWidth="640">
            <StackPanel Spacing="6">
                <TextBlock
                    Text="CleanShot"
                    FontFamily="{StaticResource DisplayFont}"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource InkPrimaryBrush}" />
                <TextBlock
                    Text="Customize shortcuts and where screenshots are saved."
                    Foreground="{StaticResource InkMutedBrush}"
                    FontFamily="{StaticResource BodyFont}" />
            </StackPanel>

            <Border
                Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource GlassEdgeBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Text="SAVE FOLDER"
                            FontFamily="{StaticResource BodyFont}"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="{StaticResource InkMutedBrush}"
                            CharacterSpacing="100" />

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                x:Name="SaveFolderBox"
                                Grid.Column="0"
                                FontFamily="{StaticResource BodyFont}"
                                FontSize="12"
                                PlaceholderText="Choose a folder…"
                                TextWrapping="Wrap" />

                            <Button
                                Grid.Column="1"
                                Style="{StaticResource DebugTileButtonStyle}"
                                Click="OnBrowseFolderClicked">
                                <TextBlock Text="Browse" FontWeight="SemiBold" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock
                            Text="SHORTCUTS"
                            FontFamily="{StaticResource BodyFont}"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="{StaticResource InkMutedBrush}"
                            CharacterSpacing="100" />

                        <TextBlock
                            Text="Focus a field and press your shortcut."
                            FontFamily="{StaticResource BodyFont}"
                            FontSize="10"
                            Foreground="{StaticResource InkMutedBrush}" />

                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="Full screen"
                                FontFamily="{StaticResource BodyFont}"
                                FontSize="11"
                                Foreground="{StaticResource InkMutedBrush}"
                                VerticalAlignment="Center" />
                            <controls:HotkeyCaptureBox
                                x:Name="FullScreenShortcutBox"
                                Grid.Row="0"
                                Grid.Column="1"
                                EnterPressed="OnShortcutEnterPressed" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="Region"
                                FontFamily="{StaticResource BodyFont}"
                                FontSize="11"
                                Foreground="{StaticResource InkMutedBrush}"
                                VerticalAlignment="Center" />
                            <controls:HotkeyCaptureBox
                                x:Name="RegionShortcutBox"
                                Grid.Row="1"
                                Grid.Column="1"
                                EnterPressed="OnShortcutEnterPressed" />
                        </Grid>
                    </StackPanel>

                    <Button
                        Style="{StaticResource DebugTilePrimaryStyle}"
                        HorizontalAlignment="Stretch"
                        Click="OnSaveClicked">
                        <TextBlock Text="Save settings" FontWeight="SemiBold" />
                    </Button>

                    <TextBlock
                        x:Name="StatusText"
                        FontFamily="{StaticResource BodyFont}"
                        FontSize="11"
                        Foreground="{StaticResource InkMutedBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
