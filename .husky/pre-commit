# Frontend: Prettier + ESLint --fix on staged JS/TS, rustfmt on staged Rust.
pnpm exec lint-staged

# Tauri: refresh tracked gen/schemas when capability manifests change.
if git diff --cached --name-only | grep -q '^apps/windows/tauri/capabilities/'; then
  echo "↳ Capability manifest changed — syncing apps/windows/tauri/gen/schemas"
  pnpm --silent run tauri:gen
  git add apps/windows/tauri/gen/schemas/
fi

# Rust: run clippy when any Rust source is staged. lint-staged has already
# run rustfmt and re-staged the results above; this gates the lint pass.
if git diff --cached --name-only --diff-filter=ACMR | grep -q '^apps/windows/tauri/.*\.rs$'; then
  echo "↳ Rust changes staged — running cargo clippy"
  cargo clippy --manifest-path apps/windows/tauri/Cargo.toml --all-targets -- -D warnings
fi
