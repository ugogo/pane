{
  "name": "pane",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "description": "Pane — Windows desktop utility suite (Tauri 2 + React + Rust)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop.ps1",
    "build": "npm run build -w @pane/windows",
    "typecheck": "npm run typecheck -w @pane/ui && npm run typecheck -w @pane/windows && npm run typecheck -w @pane/companion",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rust:fmt": "cargo fmt --manifest-path apps/windows/tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path apps/windows/tauri/Cargo.toml -- --check",
    "rust:clippy": "cargo clippy --manifest-path apps/windows/tauri/Cargo.toml --all-targets -- -D warnings",
    "tauri:gen": "node scripts/sync-tauri-gen.ts",
    "tauri:gen:check": "node scripts/sync-tauri-gen.ts --check",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-it.ps1",
    "dev:trusted": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-trusted.ps1",
    "companion": "npm run start -w @pane/companion",
    "companion:prod": "npm run start:prod -w @pane/companion",
    "companion:clear": "npm run clear -w @pane/companion",
    "companion:clear:prod": "npm run clear:prod -w @pane/companion",
    "companion:install": "npm install -w @pane/companion",
    "companion:typecheck": "npm run typecheck -w @pane/companion",
    "tauri": "npm run tauri -w @pane/windows --",
    "prepare": "husky"
  },
  "lint-staged": {
    "{apps,packages}/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,jsx,css,json,md,html,yml,yaml}": [
      "prettier --write"
    ],
    "apps/windows/tauri/**/*.rs": [
      "rustfmt --edition 2021"
    ]
  },
  "overrides": {
    "@types/react": "~19.2.16",
    "@types/react-dom": "~19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-doctor": "0.2.16",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "0.11.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.6",
    "oxc-parser": "0.133.0",
    "prettier": "3.8.3",
    "release-it": "^20.2.0",
    "typescript": "^6",
    "typescript-eslint": "8.60.0"
  }
}
