{
  "name": "pane",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Pane — Windows desktop utility suite (Tauri 2 + React + Rust)",
  "scripts": {
    "dev": "tauri dev",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release.ps1",
    "dev:trusted": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-trusted.ps1",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^1.16.0",
    "react": "^19",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vite": "^5"
  }
}
