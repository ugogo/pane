{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Home",
  "version": "0.1.0",
  "identifier": "dev.home.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Home",
        "width": 900,
        "height": 600,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": {
      "resources/capture-shutter.wav": "capture-shutter.wav"
    }
  }
}
