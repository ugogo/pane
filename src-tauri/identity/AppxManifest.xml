<?xml version="1.0" encoding="utf-8"?>
<Package IgnorableNamespaces="uap uap3 uap10 rescap"
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities">

  <!-- Identity-only sparse package. Grants pane.exe package identity so it can
       register as a Windows Dynamic Lighting background controller. Publisher
       MUST match the signing certificate subject; Name/Publisher/Application Id
       MUST match the <msix> element in windows-app-manifest.xml.
       Version is rewritten to the app version by build-identity-package.ps1. -->
  <Identity Name="Pane" Publisher="CN=Pane" Version="0.4.0.0" ProcessorArchitecture="neutral" />

  <Properties>
    <DisplayName>Pane</DisplayName>
    <PublisherDisplayName>Pane</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <!-- AllowExternalContent: required for a sparse package whose payload
         (pane.exe) lives outside the package, at the registered external
         location. Without it the package cannot bind to the on-disk exe. -->
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Capabilities>
    <!-- runFullTrust: pane.exe is a full-trust Win32 app (RuntimeBehavior
         win32App below), not a sandboxed UWP app. Required to run the existing
         exe under package identity. -->
    <rescap:Capability Name="runFullTrust" />
    <!-- unvirtualizedResources: lets the full-trust exe read/write the real
         registry and filesystem (HKCU Run key, %LOCALAPPDATA%\Pane state)
         instead of a per-package virtualized view, so packaged and unpackaged
         runs share the same settings. -->
    <rescap:Capability Name="unvirtualizedResources" />
  </Capabilities>

  <Applications>
    <Application Id="Pane" Executable="pane.exe" uap10:TrustLevel="mediumIL" uap10:RuntimeBehavior="win32App">
      <uap:VisualElements
        AppListEntry="none"
        DisplayName="Pane"
        Description="Pane desktop utility suite"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
      <Extensions>
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension Name="com.microsoft.windows.lighting" Id="Pane" DisplayName="Pane" PublicFolder="public" />
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>
</Package>
